{
  "name": "arynoxtech-jwellery-erp",
  "version": "2.0.0",
  "description": "Arynoxtech Jewellery ERP Management - The best ever Software Product for Jewellery stores",
  "author": "Arynoxtech",
  "main": "main.js",
  "scripts": {
    "start": "webpack --config webpack.config.js --mode production && electron .",
    "build": "webpack --config webpack.config.js --mode production",
    "dev": "webpack --config webpack.config.js --mode development && electron .",
    "demo": "electron demo.js",
    "pack": "electron-builder --win portable",
    "dist": "electron-builder --win",
    "publish": "npm run build && electron-builder --win --publish always",
    "release": "node scripts/publish-release.js",
    "release:ftp": "node scripts/publish-release.js --ftp",
    "release:dir": "node scripts/publish-release.js --dir",
    "test": "jest"
  },
  "build": {
    "appId": "com.arynoxtech.jwelleryerp",
    "productName": "Arynoxtech Jwellery ERP",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "demo.js",
      "dist/renderer/**/*",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png"
    },
    "publish": [{
      "provider": "github",
      "owner": "aryaanchavan1-commits",
      "repo": "Arynoxtech_Jwellery_AI_ERP",
      "releaseType": "release"
    }],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.png",
      "uninstallerIcon": "assets/icon.png",
      "installerHeaderIcon": "assets/icon.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Arynoxtech Jwellery ERP",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "dependencies": {
    "@libsql/client": "^0.6.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.11.1",
    "chart.js": "^4.4.0",
    "electron-store": "^8.1.0",
    "groq-sdk": "^0.8.0",
    "jsbarcode": "^3.12.3",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.1",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "sql.js": "^1.14.1",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "babel-jest": "^30.4.1",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "electron": "33.4.11",
    "electron-builder": "^24.9.0",
    "electron-updater": "^6.8.9",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "style-loader": "^3.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
